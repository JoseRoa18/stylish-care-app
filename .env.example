# ─────────────────────────────────────────────────────────────
#  Stylish Care App — environment configuration
#  Copy this file to ".env" and fill in the values.
#  NEVER commit the real .env file to git.
# ─────────────────────────────────────────────────────────────

# ── Gemini (AI draft generation) ─────────────────────────────
# Get a key at aistudio.google.com/apikey
GEMINI_API_KEY=
# gemini-3.1-pro-preview (default) · gemini-3.1-flash-lite · gemini-2.5-flash
GEMINI_MODEL=gemini-3.1-pro-preview

# ── Zoho Desk ────────────────────────────────────────────────
# Data center: use the .com endpoints by default. If your Zoho
# account lives in the Canadian data center, switch these to the
# .ca / zohocloud.ca equivalents (see README).
ZOHO_API_BASE=https://desk.zoho.com/api/v1
ZOHO_ACCOUNTS_BASE=https://accounts.zoho.com/oauth/v2

# OAuth credentials from api-console.zoho.com (Self Client or
# Server-based app). You need a long-lived REFRESH token here.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Stylish portal identifiers (already filled with your values)
ZOHO_ORG_ID=771779760
ZOHO_DEPARTMENT_ID=675000000000006907
ZOHO_FROM_ADDRESS=care@stylishkb.com

# Which ticket statuses to pull into the Inbox (comma separated)
ZOHO_TICKET_STATUS=Open,On Hold

# ── Knowledge Base ingestion (optional overrides) ────────────
# Pages crawled by "Import from Website" (comma separated). Leave empty to
# use the built-in Stylish support pages (faqs, returns, warranty, etc.).
WEB_KB_URLS=
# Zoho Desk endpoint for reply templates. Needs the OAuth client to include
# the Desk.settings.READ scope. Verify the exact path for your edition.
ZOHO_TEMPLATES_PATH=/emailTemplates

# ── Dropbox (optional — installation manuals) ────────────────
# Durable auth (recommended): app key/secret + a refresh token, so the
# connection never expires (the server mints short-lived tokens on demand).
# Get the refresh token via the OAuth offline flow (see README/zoho pattern).
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
# Fallback only: a static ~4h access token from the App Console.
DROPBOX_ACCESS_TOKEN=
DROPBOX_MANUALS_PATH=/Installation Manuals

# ── YouTube (optional — attach tutorial videos) ──────────────
# Needs a Google Cloud API key (AIza...) with "YouTube Data API v3" enabled.
# This is NOT the Gemini/AI Studio key. Set the channel by ID or @handle.
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=
YOUTUBE_HANDLE=
# Ingest only tutorial playlists (not marketing shorts). By default it
# discovers playlists whose title matches this filter; or pin exact playlist
# IDs with YOUTUBE_PLAYLIST_IDS (comma-separated).
YOUTUBE_PLAYLIST_FILTER=how\s*to
YOUTUBE_PLAYLIST_IDS=
YOUTUBE_MAX_VIDEOS=200

# ── Server ───────────────────────────────────────────────────
PORT=8787
# How often the Inbox auto-checks Zoho for new tickets (seconds)
POLL_INTERVAL_SECONDS=120
